<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<system.webServer>
		<handlers>
			<add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified"/>
		</handlers>
		<aspNetCore processPath="dotnet" arguments="WeatherService.dll" stdoutLogEnabled="true" stdoutLogFile="\\?\%home%\LogFiles\Application\stdout" />
	</system.webServer>
</configuration>
