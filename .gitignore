############################
# .NET / C# build output
############################
bin/
obj/
*.user
*.suo
*.userprefs
*.csproj.user
*.dbmdl
*.jfm

############################
# Visual Studio / Rider
############################
.vs/
.idea/
*.swp
*.sln.docstates

############################
# Logs
############################
*.log
logs/

############################
# ASP.NET Core
############################
wwwroot/lib/
wwwroot/dist/
wwwroot/node_modules/

############################
# Node / JS tooling
############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################
# gRPC / Protobuf
############################

# C# generated gRPC code (should NOT be committed)
# These are regenerated automatically by MSBuild
**/obj/**/Protos/*.cs

# JS gRPC-Web generated files (optional)
# If you want reproducible builds, ignore them.
# If you want to serve them directly, keep them.
wwwroot/generated/*.js

# Protoc tooling (if you installed locally)
protoc/
protoc-gen-grpc-web.exe

############################
# Environment / secrets
############################
*.env
*.env.*
appsettings.Development.json
appsettings.Local.json

############################
# OS junk
############################
Thumbs.db
.DS_Store
